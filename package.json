{
	"name": "@feedbakkr/sdk",
	"version": "0.1.1",
	"description": "Lightweight SDK for submitting messages to Feedbakkr",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist", "README.md", "LICENSE"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"security:audit": "npm audit --audit-level=high",
		"security:audit:moderate": "npm audit --audit-level=moderate",
		"security:osv": "osv-scanner --recursive .",
		"security:scan": "npm run security:audit",
		"security:scan:full": "npm run security:audit:moderate && npm run security:osv",
		"verify:publish": "npm test && npm run typecheck && npm run security:audit && npm run build && npm pack --dry-run",
		"prepublishOnly": "npm run verify:publish"
	},
	"engines": {
		"node": ">=22"
	},
	"keywords": [
		"feedbakkr",
		"feedback",
		"sdk",
		"api-client",
		"typescript"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/feedbakkr/feedbakkr-sdk"
	},
	"homepage": "https://github.com/feedbakkr/feedbakkr-sdk#readme",
	"bugs": {
		"url": "https://github.com/feedbakkr/feedbakkr-sdk/issues"
	},
	"devDependencies": {
		"tsup": "^8.0.0",
		"typescript": "~5.8.0",
		"vitest": "^3.0.0"
	}
}
